# Required: LaunchDarkly server-side SDK key (Account settings > Projects > your project > Environments)
LD_SDK_KEY=sdk-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Port the demo HTTP server listens on (optional, defaults to 8080)
PORT=8080

# Optional: only needed if you wire up the real AI Config remediation advisor to an
# actual model provider. If unset, the advisor falls back to a canned response so the
# rest of the demo works without an LLM key.
ANTHROPIC_API_KEY=
